{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flask Dev Server",
      "runtimeExecutable": "venv/bin/python",
      "runtimeArgs": ["app.py"],
      "port": 5000
    },
    {
      "name": "Gunicorn",
      "runtimeExecutable": "venv/bin/gunicorn",
      "runtimeArgs": ["--workers", "2", "--bind", "127.0.0.1:5000", "--timeout", "600", "app:app"],
      "port": 5000
    }
  ]
}
