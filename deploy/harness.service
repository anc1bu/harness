[Unit]
Description=Harness Flask backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/harness
Environment="HARNESS_DATA=/var/www/harness/data"
Environment="HARNESS_NO_AUTH=1"
EnvironmentFile=-/var/www/harness/.env
ExecStart=/var/www/harness/venv/bin/gunicorn \
    --workers 2 \
    --bind 127.0.0.1:5000 \
    --timeout 120 \
    --access-logfile - \
    app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
